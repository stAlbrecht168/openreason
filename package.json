{
  "name": "openreason",
  "version": "0.1.0",
  "description": "Transparent reasoning framework compiler and Claude Code analysis workspace.",
  "type": "module",
  "bin": {
    "openreason": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "validate": "tsx src/cli.ts validate",
    "compile": "tsx src/cli.ts compile examples/iran-somalia.md --out compiled_prompt.md",
    "analyze": "tsx src/cli.ts analyze examples/iran-somalia.md --out reports/iran-somalia.report.md",
    "inspect": "tsx src/cli.ts inspect examples/iran-somalia.md",
    "health": "tsx validators/health.ts",
    "cc:check": "npm run validate && npm test",
    "cc:health": "npm run validate && npm run health",
    "cc:smoke": "npm run validate && npm test && npm run build && npm run analyze"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
